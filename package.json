{
  "name": "srgical-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @srgical/studio-shared && npm run build -w @srgical/studio-core && npm run build -w @srgical/studio-web && npm run build -w @launcheleven/srgical",
    "dev": "npm run dev -w @launcheleven/srgical --",
    "start": "npm run start -w @launcheleven/srgical --",
    "status": "npm run status -w @launcheleven/srgical --",
    "test": "npm run test -w @launcheleven/srgical",
    "test:coverage": "npm run test:coverage -w @launcheleven/srgical",
    "prepack": "npm run build",
    "release:pack": "node scripts/release-pack.mjs",
    "publish:github": "node scripts/publish-github.mjs",
    "publish:npm": "node scripts/publish-npm.mjs",
    "release:version": "node scripts/read-package-version.mjs",
    "release:state": "node scripts/read-release-state.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
